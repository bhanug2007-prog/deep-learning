# ============================================================
# AI Answer Evaluation System — .gitignore
# ============================================================

# --- Environment ---
.env
*.env

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# --- Virtual Environment ---
venv/
env/
.venv/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Model Weights (large files → use Git LFS or store externally) ---
models/saved/*.pth
models/saved/*.pt
models/saved/*.bin

# --- Dataset (large files) ---
dataset/raw/
dataset/iam_sample/

# --- Uploads / temp OCR ---
uploads/
temp/

# --- Logs ---
*.log
logs/

# --- OS ---
.DS_Store
Thumbs.db

# --- IDE ---
.vscode/
.idea/
*.swp
