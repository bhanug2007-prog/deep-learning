# ============================================================
# AI Answer Evaluation System — Environment Configuration
# Phase 1: Project Setup
# INSTRUCTIONS: Copy this file → rename to .env → fill values
# ============================================================

# --- Application ---
APP_NAME="AI Answer Evaluation System"
APP_ENV=development
APP_DEBUG=True
APP_PORT=8000
SECRET_KEY=change-this-to-a-long-random-secret-key

# --- Database (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_evaluation_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost:3306/ai_evaluation_db

# --- Model Paths ---
CRNN_MODEL_PATH=models/saved/crnn_finetuned.pth
SBERT_MODEL_NAME=all-MiniLM-L6-v2
TESSERACT_CMD=/usr/bin/tesseract

# --- OCR Settings ---
OCR_CONFIDENCE_THRESHOLD=0.6
OCR_ENGINE=hybrid

# --- Scoring Weights (must sum to 1.0) ---
SEMANTIC_WEIGHT=0.5
KEYWORD_WEIGHT=0.3
GRAMMAR_WEIGHT=0.2

# --- File Upload ---
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf
UPLOAD_DIR=uploads/

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
